# ─── LLM Providers ────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# ─── Langfuse Tracing (optional) ──────────────────────────────────────────────
# Get keys from https://cloud.langfuse.com (or your self-hosted instance)
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key_here
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── Document Parsing (optional) ──────────────────────────────────────────────
LLAMA_PARSE_API_KEY=your_llama_parse_api_key_here

# ─── Graph DB (optional) ──────────────────────────────────────────────────────
NEO4J_USERNAME=your_neo4j_username
NEO4J_PASSWORD=your_neo4j_password

# ─── Infrastructure ───────────────────────────────────────────────────────────
# When running locally:  leave as defaults
# When running in Docker: these are set via docker-compose.yaml automatically
QDRANT_URL=http://localhost:6333
REDIS_URL=redis://localhost:6379

# ─── CORS (comma-separated allowed origins) ───────────────────────────────────
# Example for local dev: http://localhost:3000,http://localhost:8000
# Example for production: https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:8000

# ─── Qdrant Collection ────────────────────────────────────────────────────────
QDRANT_COLLECTION_NAME=global_rag_store
