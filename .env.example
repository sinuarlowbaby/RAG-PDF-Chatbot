# ─── LLM Providers ────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# ─── LangSmith Tracing (optional) ─────────────────────────────────────────────
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT="RAG-PDF-Chatbot"

# ─── Document Parsing (optional) ──────────────────────────────────────────────
LLAMA_PARSE_API_KEY=your_llama_parse_api_key_here

# ─── Graph DB (optional) ──────────────────────────────────────────────────────
NEO4J_USERNAME=your_neo4j_username
NEO4J_PASSWORD=your_neo4j_password

# ─── Infrastructure ───────────────────────────────────────────────────────────
# When running locally:  leave as defaults
# When running in Docker: these are set via docker-compose.yaml automatically
QDRANT_URL=http://localhost:6333
REDIS_URL=redis://localhost:6379

# ─── CORS (comma-separated allowed origins) ───────────────────────────────────
# Example for local dev: http://localhost:3000,http://localhost:8000
# Example for production: https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:8000

# ─── Qdrant Collection ────────────────────────────────────────────────────────
QDRANT_COLLECTION_NAME=global_rag_store
